# Copy to apps/server/.env for local development (it is gitignored).
# All optional — the app runs fully without any of these.

# Enables the Gemini vision detection layer. Without it, detection is heuristic-only.
GEMINI_API_KEY=
# Detection model (defaults to gemini-3.5-flash if unset).
# GEMINI_MODEL=gemini-3.5-flash

# Server port / CORS (sensible local defaults are built in).
# PORT=4000
# CORS_ORIGINS=http://localhost:3000
